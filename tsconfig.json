{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": false,
		"exactOptionalPropertyTypes": true,
		"ignoreDeprecations": "6.0",
		"isolatedModules": true,
		"module": "nodenext",
		"moduleDetection": "force",
		"noUncheckedIndexedAccess": true,
		"noUncheckedSideEffectImports": true,
		"outDir": "./dist",
		"removeComments": true,
		"rootDir": "./src",
		"skipLibCheck": true,
		"sourceMap": false,
		"strict": true,
		"target": "esnext",
		"types": []
	},
	"include": ["src/**/*.ts"]
}
