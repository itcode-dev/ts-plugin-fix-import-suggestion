{
	"author": "RWB <psj2716@gmail.com>",
	"description": "A TypeScript Language Service Plugin that fixes wrong .js/.jsx auto-import suggestions for Turborepo JIT packages in editors like VS Code.",
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@itcode-dev/biome-config": "^1.1.0",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.10",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"keywords": [
		"typescript",
		"typescript-plugin",
		"tsserver-plugin",
		"language-service-plugin",
		"turborepo",
		"jit-packages",
		"monorepo",
		"auto-import",
		"vscode",
		"intellisense"
	],
	"license": "MIT",
	"main": "dist/index.cjs",
	"name": "@itcode-dev/ts-plugin-fix-import-suggestion",
	"scripts": {
		"build": "tsdown",
		"check": "biome check",
		"pretest": "tsdown",
		"pretest:coverage": "tsdown",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"type": "commonjs",
	"types": "dist/index.d.cts",
	"version": "1.1.0"
}
